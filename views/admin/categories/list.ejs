<% locals.currentPath = 'categorias'; %>
<%- include('../partials/layout-start') %>

<div class="page-header">
  <div>
    <h1>Categorías</h1>
    <p>Gestiona las categorías disponibles para los productos</p>
  </div>
  <button class="btn btn-primary" onclick="document.getElementById('modal-nueva').showModal()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nueva categoría
  </button>
</div>

<% if (error) { %>
<div class="alert alert-error" id="alert-box">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
  <%= error %>
</div>
<% } %>
<% if (success) { %>
<div class="alert alert-success" id="alert-box">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
  <%= success %>
</div>
<% } %>

<!-- Categories Grid -->
<div class="cat-grid">
  <% categories.forEach(function(cat) { %>
  <div class="cat-card <%= cat.active ? '' : 'cat-inactive' %>">
    <div class="cat-card-header">
      <div class="cat-icon" style="background:<%= cat.color %>22; color:<%= cat.color %>; border: 1.5px solid <%= cat.color %>44">
        <%= cat.icon %>
      </div>
      <div class="cat-info">
        <span class="cat-name"><%= cat.name %></span>
        <span class="cat-desc"><%= cat.description || 'Sin descripción' %></span>
      </div>
      <div class="cat-badge-wrap">
        <span class="badge <%= cat.active ? 'badge-green' : 'badge-gray' %>">
          <%= cat.active ? 'Activa' : 'Inactiva' %>
        </span>
      </div>
    </div>
    <div class="cat-card-body">
      <div class="cat-stat">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        <span><strong><%= countMap[cat.name] || 0 %></strong> producto(s)</span>
      </div>
      <div class="cat-color-dot" style="background:<%= cat.color %>" title="Color: <%= cat.color %>"></div>
    </div>
    <div class="cat-card-actions">
      <button class="btn btn-secondary btn-sm"
        onclick='openEdit(<%= JSON.stringify({id:cat.id, name:cat.name, description:cat.description||"", color:cat.color, icon:cat.icon, active:cat.active}) %>)'>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Editar
      </button>
      <button class="btn btn-sm cat-toggle-btn <%= cat.active ? 'btn-warning' : 'btn-success' %>"
        onclick="toggleCat(<%= cat.id %>, this)">
        <%= cat.active ? 'Desactivar' : 'Activar' %>
      </button>
      <% if ((countMap[cat.name] || 0) === 0) { %>
      <form method="POST" action="/admin/categorias/<%= cat.id %>?_method=DELETE" style="display:inline"
        onsubmit="return confirm('¿Eliminar la categoría «<%= cat.name %>»? Esta acción no se puede deshacer.')">
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" class="btn btn-danger btn-sm">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          Eliminar
        </button>
      </form>
      <% } else { %>
      <button class="btn btn-sm" style="opacity:.4;cursor:not-allowed" title="No se puede eliminar: tiene productos asociados" disabled>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
        Eliminar
      </button>
      <% } %>
    </div>
  </div>
  <% }) %>

  <% if (categories.length === 0) { %>
  <div class="cat-empty">
    <div style="font-size:3rem;margin-bottom:.75rem">🏷️</div>
    <p>No hay categorías aún. <button class="link-btn" onclick="document.getElementById('modal-nueva').showModal()">Crear la primera</button></p>
  </div>
  <% } %>
</div>

<!-- ── MODAL NUEVA CATEGORÍA ── -->
<dialog id="modal-nueva" class="cat-modal">
  <div class="cat-modal-inner">
    <div class="cat-modal-header">
      <h2>Nueva categoría</h2>
      <button class="modal-close" onclick="document.getElementById('modal-nueva').close()">✕</button>
    </div>
    <form method="POST" action="/admin/categorias" class="cat-form">
      <div class="form-group">
        <label for="new-name">Nombre <span class="req">*</span></label>
        <input type="text" id="new-name" name="name" placeholder="ej: aceites, velas..." required class="form-control">
        <small class="form-hint">Se normalizará a minúsculas con guiones bajos (ej: aceites_esenciales)</small>
      </div>
      <div class="form-group">
        <label for="new-desc">Descripción</label>
        <input type="text" id="new-desc" name="description" placeholder="Descripción corta opcional" class="form-control">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="new-icon">Emoji / Icono</label>
          <input type="text" id="new-icon" name="icon" placeholder="🏷️" maxlength="6" class="form-control" value="🏷️">
        </div>
        <div class="form-group">
          <label for="new-color">Color</label>
          <input type="color" id="new-color" name="color" value="#a78bfa" class="form-control color-input">
        </div>
      </div>
      <div class="form-group">
        <label class="toggle-label">
          <input type="checkbox" name="active" checked>
          <span>Activa (visible en formulario de productos)</span>
        </label>
      </div>
      <div class="cat-form-actions">
        <button type="button" class="btn btn-secondary" onclick="document.getElementById('modal-nueva').close()">Cancelar</button>
        <button type="submit" class="btn btn-primary">Crear categoría</button>
      </div>
    </form>
  </div>
</dialog>

<!-- ── MODAL EDITAR CATEGORÍA ── -->
<dialog id="modal-editar" class="cat-modal">
  <div class="cat-modal-inner">
    <div class="cat-modal-header">
      <h2>Editar categoría</h2>
      <button class="modal-close" onclick="document.getElementById('modal-editar').close()">✕</button>
    </div>
    <form id="edit-form" method="POST" class="cat-form">
      <input type="hidden" name="_method" value="PUT">
      <div class="form-group">
        <label for="edit-name">Nombre <span class="req">*</span></label>
        <input type="text" id="edit-name" name="name" required class="form-control">
      </div>
      <div class="form-group">
        <label for="edit-desc">Descripción</label>
        <input type="text" id="edit-desc" name="description" class="form-control">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="edit-icon">Emoji / Icono</label>
          <input type="text" id="edit-icon" name="icon" maxlength="6" class="form-control">
        </div>
        <div class="form-group">
          <label for="edit-color">Color</label>
          <input type="color" id="edit-color" name="color" class="form-control color-input">
        </div>
      </div>
      <div class="form-group">
        <label class="toggle-label">
          <input type="checkbox" id="edit-active" name="active">
          <span>Activa</span>
        </label>
      </div>
      <div class="cat-form-actions">
        <button type="button" class="btn btn-secondary" onclick="document.getElementById('modal-editar').close()">Cancelar</button>
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
      </div>
    </form>
  </div>
</dialog>

<style>
/* ── Category page styles ── */
.cat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.25rem;
  margin-top: 0;
}
.cat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: box-shadow .2s, transform .2s;
}
.cat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.cat-inactive { opacity: .6; }
.cat-card-header {
  display: flex;
  align-items: center;
  gap: .875rem;
  padding: 1.1rem 1.25rem .7rem;
}
.cat-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
  flex-shrink: 0;
}
.cat-info { flex: 1; min-width: 0; }
.cat-name {
  display: block;
  font-weight: 700;
  font-size: .95rem;
  color: var(--text);
  text-transform: capitalize;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.cat-desc {
  display: block;
  font-size: .78rem;
  color: var(--text-muted);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.cat-card-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .4rem 1.25rem .75rem;
  border-bottom: 1px solid var(--border);
}
.cat-stat {
  display: flex; align-items: center; gap: .4rem;
  font-size: .82rem; color: var(--text-muted);
}
.cat-color-dot {
  width: 18px; height: 18px;
  border-radius: 50%;
  border: 2px solid var(--border);
}
.cat-card-actions {
  display: flex; align-items: center; gap: .5rem;
  padding: .75rem 1.25rem;
  flex-wrap: wrap;
}
.cat-empty {
  grid-column: 1/-1;
  text-align: center;
  padding: 3rem;
  color: var(--text-muted);
}
.link-btn {
  background: none; border: none; cursor: pointer;
  color: var(--accent); font-size: inherit;
  text-decoration: underline;
}

/* Alert banners */
.alert {
  display: flex; align-items: center; gap: .6rem;
  padding: .85rem 1.1rem;
  border-radius: var(--radius);
  margin-bottom: 1.25rem;
  font-size: .88rem;
}
.alert-error  { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
.alert-success{ background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }

/* Modal */
.cat-modal {
  border: none;
  border-radius: var(--radius-lg);
  background: var(--surface);
  box-shadow: var(--shadow-lg);
  padding: 0;
  width: min(540px, 96vw);
  max-height: 92vh;
  overflow-y: auto;
}
.cat-modal::backdrop { background: rgba(0,0,0,.55); backdrop-filter: blur(3px); }
.cat-modal-inner { padding: 1.75rem 2rem; }
.cat-modal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1.5rem;
}
.cat-modal-header h2 { font-size: 1.15rem; font-weight: 700; color: var(--text); }
.modal-close {
  background: none; border: none; cursor: pointer;
  font-size: 1.1rem; color: var(--text-muted);
  padding: .25rem .5rem; border-radius: var(--radius);
  transition: background .15s;
}
.modal-close:hover { background: var(--border); }
.cat-form .form-group { margin-bottom: 1.1rem; }
.cat-form label { display: block; font-size: .82rem; font-weight: 600; color: var(--text-muted); margin-bottom: .4rem; }
.cat-form .form-control {
  width: 100%; padding: .6rem .85rem;
  border: 1px solid var(--border); border-radius: var(--radius);
  background: var(--bg); color: var(--text);
  font-size: .9rem; font-family: inherit;
  transition: border-color .15s, box-shadow .15s;
  box-sizing: border-box;
}
.cat-form .form-control:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
.color-input { height: 42px; padding: .25rem .4rem; cursor: pointer; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-hint { font-size: .73rem; color: var(--text-muted); margin-top: .25rem; display: block; }
.toggle-label { display: flex !important; flex-direction: row !important; align-items: center; gap: .5rem; cursor: pointer; }
.toggle-label input { width: auto; }
.req { color: var(--danger); }
.cat-form-actions { display: flex; justify-content: flex-end; gap: .75rem; margin-top: 1.5rem; }

/* Btn variants */
.btn-warning { background: var(--warning); color: #fff; border-color: transparent; }
.btn-warning:hover { filter: brightness(1.1); }
.btn-success { background: var(--success); color: #fff; border-color: transparent; }
.btn-success:hover { filter: brightness(1.1); }
</style>

<script>
function openEdit(cat) {
  document.getElementById('edit-name').value  = cat.name;
  document.getElementById('edit-desc').value  = cat.description;
  document.getElementById('edit-icon').value  = cat.icon;
  document.getElementById('edit-color').value = cat.color;
  document.getElementById('edit-active').checked = !!cat.active;
  document.getElementById('edit-form').action = `/admin/categorias/${cat.id}?_method=PUT`;
  document.getElementById('modal-editar').showModal();
}

function toggleCat(id, btn) {
  fetch(`/admin/categorias/${id}/toggle`, { method: 'PATCH' })
    .then(r => r.json())
    .then(d => { if (d.success) location.reload(); });
}

// Auto-dismiss alerts
const alertBox = document.getElementById('alert-box');
if (alertBox) setTimeout(() => alertBox.style.display = 'none', 4000);
</script>

<%- include('../partials/layout-end') %>
