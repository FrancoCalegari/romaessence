<% locals.currentPath = 'productos'; %>
<%- include('../partials/layout-start') %>

<div class="page-header">
  <div>
    <h1>Productos</h1>
    <p><%= products.length %> producto(s) en total</p>
  </div>
  <a href="/admin/productos/nuevo" class="btn btn-primary">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nuevo producto
  </a>
</div>

<div class="card">
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Foto</th>
          <th>Nombre</th>
          <th>Categoría</th>
          <th>Precio costo</th>
          <th>Precio venta</th>
          <th>Stock</th>
          <th>Rating</th>
          <th>Banner</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(p) { %>
        <tr>
          <td>
            <div class="td-img">
              <% if (p.photo_file_id) { %>
              <img src="/files/<%= p.photo_file_id %>" alt="">
              <% } else { %><div class="no-img">🌸</div><% } %>
            </div>
          </td>
          <td>
            <div><strong><%= p.name %></strong></div>
            <div style="font-size:0.75rem;color:var(--text-muted);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <%= p.description.substring(0,60) %>
            </div>
          </td>
          <td><span class="badge badge-purple"><%= p.category %></span></td>
          <td style="color:var(--text-muted);">$ <%= parseFloat(p.cost_price).toFixed(2) %></td>
          <td style="font-weight:500;">$ <%= p.sell_price.toFixed(2) %></td>
          <td>
            <span class="badge <%= p.stock===0?'badge-red':p.stock<5?'badge-amber':'badge-green' %>">
              <%= p.stock %>
            </span>
          </td>
          <td>★ <%= p.rating %></td>
          <td>
            <% if (p.banner_file_id) { %>
            <span class="badge badge-green">✓</span>
            <% } else { %>
            <span class="badge badge-gray">—</span>
            <% } %>
          </td>
          <td>
            <label class="toggle-switch" title="<%= p.active ? 'Activo' : 'Inactivo' %>">
              <input type="checkbox" <%= p.active ? 'checked' : '' %>
                     data-toggle-url="/admin/productos/<%= p.id %>/toggle">
              <span class="toggle-slider"></span>
            </label>
          </td>
          <td>
            <div class="td-actions">
              <a href="/producto/<%= p.id %>" target="_blank" class="btn btn-secondary btn-sm btn-icon" title="Ver">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </a>
              <a href="/admin/productos/<%= p.id %>/editar" class="btn btn-gold btn-sm btn-icon" title="Editar">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </a>
              <form action="/admin/productos/<%= p.id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-danger btn-sm btn-icon"
                        data-confirm="¿Eliminar el producto '<%= p.name %>'? Esta acción no se puede deshacer." title="Eliminar">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
        <% if (products.length === 0) { %>
        <tr><td colspan="10" style="text-align:center;color:var(--text-muted);padding:3rem;">
          Sin productos. <a href="/admin/productos/nuevo" style="color:var(--accent);">Crear primero</a>
        </td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/layout-end') %>
