<%- include('partials/header') %>

<main>

  <!-- ── BANNER SECTION ─────────────────────────────── -->
  <% if (bannerProducts.length > 0) { %>
  <section class="banner-section">
    <div class="section-title" style="margin-bottom:0.3rem;">Destacados</div>
    <div class="section-subtitle">nuestra selección</div>
    <div class="banner-carousel-wrapper" style="position: relative; overflow: hidden; border-radius: var(--radius-lg);">
      <div class="banner-carousel" id="featured-banner-carousel" style="display: flex; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);">
        <% bannerProducts.forEach(function(p) { %>
        <a href="/producto/<%= p.id %>" class="banner-slide" style="flex-shrink: 0; width: 100%; position: relative; aspect-ratio: 16/9; display: block; overflow: hidden;">
          <% if (p.banner_file_id) { %>
            <img src="/files/<%= p.banner_file_id %>" alt="<%= p.name %>" style="width: 100%; height: 100%; object-fit: cover;">
          <% } else { %>
            <div style="background:var(--bg-3);width:100%;height:100%;"></div>
          <% } %>
        </a>
        <% }) %>
      </div>
      <% if (bannerProducts.length > 1) { %>
      <div class="banner-controls" style="position: absolute; bottom: 2rem; right: 2rem; display: flex; gap: 0.5rem; z-index: 10;">
        <% bannerProducts.forEach(function(_, i) { %>
        <div class="banner-dot <%= i===0?'active':'' %>" data-index="<%= i %>"></div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </section>
  <% } %>

  <!-- ── PROMOTIONS CAROUSEL ────────────────────────── -->
  <% if (promotions.length > 0) { %>
  <section class="promos-section">
    <div class="section-title">Promociones</div>
    <div class="section-subtitle">ofertas y anuncios</div>
    <div class="promo-carousel-wrapper">
      <div class="promo-carousel">
        <div class="promo-track">
          <% promotions.forEach(function(promo) { %>
          <div class="promo-card" <% if(promo.link){ %>onclick="window.open('<%= promo.link %>','_blank')" style="cursor:pointer;"<% } %>>
            <img src="/files/<%= promo.image_file_id %>" alt="Promoción">
          </div>
          <% }) %>
        </div>
      </div>
      <% if (promotions.length > 1) { %>
      <div class="carousel-controls">
        <button class="carousel-btn carousel-prev" aria-label="Anterior">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="carousel-dots">
          <% promotions.forEach(function(_, i) { %>
          <div class="carousel-dot <%= i===0?'active':'' %>"></div>
          <% }) %>
        </div>
        <button class="carousel-btn carousel-next" aria-label="Siguiente">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
      <% } %>
    </div>
  </section>
  <% } %>

  <!-- ── FILTERS ─────────────────────────────────────── -->
  <section class="filters-section">
    <div class="filters-row">
      <span class="filter-label">Categoría</span>
      <div class="filter-chips">
        <button class="filter-chip <%= !selectedCategory ? 'active' : '' %>" data-cat-filter="">Todas</button>
        <% categories.forEach(function(cat) { %>
        <button class="filter-chip <%= selectedCategory === cat.name ? 'active' : '' %>" data-cat-filter="<%= cat.name %>">
          <%= cat.name.charAt(0).toUpperCase() + cat.name.slice(1) %>
        </button>
        <% }) %>
      </div>
      <input type="hidden" name="category" value="">
      <select id="sort-select" class="sort-select">
        <option value="rating">Mejor puntuados</option>
        <option value="price_asc">Precio: menor a mayor</option>
        <option value="price_desc">Precio: mayor a menor</option>
        <option value="name">Nombre A-Z</option>
      </select>
    </div>


  </section>

  <!-- ── MEJORES PRODUCTOS ──────────────────────────── -->
  <% if (!search && topProducts && topProducts.length > 0) { %>
  <section class="top-products-section">
    <div class="section-title">Mejores Productos</div>
    <div class="section-subtitle">los favoritos de nuestros clientes</div>
    <div class="product-grid" style="margin-bottom: 2rem;">
      <% topProducts.forEach(function(p) { %>
        <%- include('partials/product-card', { p }) %>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- ── CATALOG GRID ────────────────────────────────── -->
  <section class="catalog-section">
    <% if (!search && !selectedCategory) { %>
      <div class="section-title" style="margin-top: 1rem;">Catálogo</div>
      <div class="section-subtitle">explora nuestras colecciones</div>
    <% } else if (search || selectedCategory) { %>
      <div class="section-title" style="margin-top: 1rem;">Resultados</div>
      <div class="section-subtitle">búsqueda y filtros</div>
    <% } %>

    <% if (products.length > 0) { %>
      
      <% 
        let catsToRender = categories;
        if (selectedCategory) {
          catsToRender = categories.filter(c => c.name === selectedCategory);
        }
      %>

      <% catsToRender.forEach(function(cat) { %>
        <% const catProducts = products.filter(p => p.category === cat.name); %>
        <% if (catProducts.length > 0) { %>
          <div class="category-group" style="margin-bottom: 4rem;">
            <div class="category-group-header" style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border);">
              <span style="font-size:1.5rem;background:<%= cat.color %>22;color:<%= cat.color %>;width:44px;height:44px;display:flex;align-items:center;justify-content:center;border-radius:12px;"><%= cat.icon %></span>
              <h2 style="font-size:1.4rem;font-weight:600;text-transform:capitalize;margin:0;"><%= cat.name %></h2>
            </div>
            <div class="product-grid" id="product-grid-<%= cat.name %>">
              <% catProducts.forEach(function(p) { %>
                <%- include('partials/product-card', { p }) %>
              <% }) %>
            </div>
          </div>
        <% } %>
      <% }) %>

      <% 
        // Productos huérfanos (sin categoría válida o antigua)
        const knownCatNames = categories.map(c => c.name);
        const otherProducts = products.filter(p => !knownCatNames.includes(p.category));
      %>
      <% if (otherProducts.length > 0) { %>
        <div class="category-group" style="margin-bottom: 4rem;">
          <div class="category-group-header" style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border);">
            <span style="font-size:1.5rem;background:var(--bg-3);width:44px;height:44px;display:flex;align-items:center;justify-content:center;border-radius:12px;">📦</span>
            <h2 style="font-size:1.4rem;font-weight:600;margin:0;">Otros Productos</h2>
          </div>
          <div class="product-grid" id="product-grid-otros">
            <% otherProducts.forEach(function(p) { %>
              <%- include('partials/product-card', { p }) %>
            <% }) %>
          </div>
        </div>
      <% } %>

    <% } else { %>
      <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <h3>Sin resultados</h3>
        <p>No encontramos productos que coincidan con tu búsqueda.</p>
        <a href="/" style="color:var(--gold);margin-top:1rem;display:inline-block;">Ver todo el catálogo</a>
      </div>
    <% } %>
  </section>

</main>

<script src="/js/catalog.js"></script>
<%- include('partials/footer') %>
